{
  "title": "Sổ Đỏ DD — overview",
  "uid": "sodo-dd-overview",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "stat",
      "title": "Jobs / 5min",
      "targets": [{ "expr": "sum(increase(http_requests_total{handler=~\".*/due-diligence/jobs\"}[5m]))" }]
    },
    {
      "type": "timeseries",
      "title": "p95 latency",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))" }]
    },
    {
      "type": "stat",
      "title": "Queue depth",
      "targets": [{ "expr": "celery_tasks_active" }]
    }
  ]
}
