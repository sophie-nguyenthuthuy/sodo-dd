# ───── Core
APP_ENV=local                  # local | staging | production
APP_NAME=sodo-dd
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string

# ───── Database
POSTGRES_USER=sodo
POSTGRES_PASSWORD=sodo
POSTGRES_DB=sodo_dd
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://sodo:sodo@postgres:5432/sodo_dd

# ───── Redis / queue
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ───── Object storage (S3 / MinIO)
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=ap-southeast-1
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_admin_secret
S3_BUCKET=sodo-dd
S3_FORCE_PATH_STYLE=true

# ───── Field-level encryption (KMS-rotated in prod)
FIELD_ENCRYPTION_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
FIELD_ENCRYPTION_KEY_ID=local-dev

# ───── Auth
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14
API_KEY_PREFIX=sk_

# ───── OCR
OCR_ENGINE=tesseract           # tesseract | vietocr | google_vision
TESSERACT_LANG=vie+eng
OCR_DPI=300

# ───── External adapters (mock=stub responses for local dev)
LAND_PORTAL_BASE_URL=https://dichvucong.gov.vn/p/home
LAND_PORTAL_MODE=mock          # mock | live
LAND_PORTAL_API_KEY=
ZONING_PROVIDER=mock           # mock | hanoi | hcmc | danang
TRANSACTION_HISTORY_PROVIDER=mock

# ───── Rate limiting (per API key)
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ───── Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS_ENABLED=true

# ───── Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Sổ Đỏ DD
